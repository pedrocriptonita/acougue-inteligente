# ============================================================
#  AÇOUGUE INTELIGENTE — Variáveis de Ambiente
#  Copie para .env.local e preencha. NUNCA commite .env.local
# ============================================================

# ---------- Supabase (Fase 2) ----------
# Painel: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://SEU_PROJETO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua-anon-key"
# Service role: usado APENAS server-side (escrita via N8N). NUNCA expor no client.
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"

# ---------- Banco de Dados / Prisma (Fase 2) ----------
# Connection string do Postgres do Supabase (use a porta 6543 do pooler para serverless)
DATABASE_URL="postgresql://postgres.SEU_PROJETO:SENHA@aws-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# URL direta (porta 5432) usada pelo prisma migrate
DIRECT_URL="postgresql://postgres.SEU_PROJETO:SENHA@aws-region.pooler.supabase.com:5432/postgres"

# ---------- OpenAI (Fase 3) ----------
OPENAI_API_KEY="sk-..."

# ---------- Evolution API / WhatsApp (Fase 3) ----------
EVOLUTION_API_URL="https://evolution.seudominio.com"
EVOLUTION_API_KEY="sua-chave-evolution"
EVOLUTION_INSTANCE_NAME="acougue-instance"

# ---------- PrintNode (Fase 3) ----------
PRINTNODE_API_KEY="sua-chave-printnode"
PRINTNODE_PRINTER_ID="123456"

# ---------- N8N (Fase 4) ----------
N8N_WEBHOOK_URL="https://n8n.seudominio.com/webhook"
# Chave compartilhada entre N8N e as rotas /api/n8n/* (mín. 32 chars aleatórios)
INTERNAL_API_KEY="gere-uma-chave-aleatoria-longa-aqui"

# ---------- App ----------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

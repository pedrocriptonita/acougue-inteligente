# ============================================================
#  Infra VPS — copie para infra/.env e preencha
# ============================================================

# Postgres (estado do N8N e Evolution API)
POSTGRES_USER=ai_admin
POSTGRES_PASSWORD=troque-esta-senha-forte
POSTGRES_DB=ai_infra

# N8N
N8N_HOST=n8n.seudominio.com
N8N_USER=admin
N8N_PASSWORD=troque-esta-senha
# Gere com: openssl rand -hex 24
N8N_ENCRYPTION_KEY=chave-de-criptografia-aleatoria

# Evolution API
EVOLUTION_HOST=evolution.seudominio.com
# Gere com: openssl rand -hex 24
EVOLUTION_API_KEY=chave-evolution-aleatoria

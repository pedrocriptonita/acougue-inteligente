{
  "name": "acougue-inteligente",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-http-header-size=65536 next dev",
    "build": "next build",
    "start": "cross-env NODE_OPTIONS=--max-http-header-size=65536 next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
